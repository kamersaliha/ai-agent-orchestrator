# Copy to `.env` and adjust. All variables are prefixed APP_ (see app/core/config.py).

APP_ENVIRONMENT=local
APP_LOG_LEVEL=INFO

# --- LLM provider: 'mock' (offline, default), 'anthropic' (Claude), or 'local' (Ollama/vLLM) ---
APP_LLM_PROVIDER=mock
# Cloud (Claude):
# APP_ANTHROPIC_API_KEY=sk-ant-...
# APP_ANTHROPIC_MODEL=claude-opus-4-8
# APP_ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5
# Local open-source via Ollama (default URL shown):
# APP_LOCAL_BASE_URL=http://localhost:11434/v1
# APP_LOCAL_MODEL=llama3.2:1b
# APP_LOCAL_ROUTER_MODEL=          # set to your fine-tuned router model tag

# --- Routing ---
APP_SEMANTIC_ROUTER_THRESHOLD=0.62

# --- Vector store: ':memory:' (default) or a path like ./qdrant_storage ---
APP_QDRANT_LOCATION=:memory:
APP_QDRANT_COLLECTION=support_kb
APP_RAG_TOP_K=3

# --- Streaming: per-token delay (ms) for the mock generator (simulates TTS pacing) ---
APP_STREAM_TOKEN_DELAY_MS=12
